.POSIX:
.SUFFIXES: .c .h .d .o .tst .trs

SHELL = /bin/sh

CC = @CC@
CFLAGS = @CFLAGS@
CPPFLAGS = @CPPFLAGS@
LDFLAGS = @LDFLAGS@
LDLIBS = @LIBS@
YASH_RUNNER = @YASH_RUNNER@

SOURCES = checkfg.c loginexec.c ptwrap.c ptyfeed.c resetsig.c
TESTERS = $(SOURCES:.c=)

POSIX_SIGNAL_TEST_SOURCES = sigcont1-p.tst sigcont2-p.tst sigcont3-p.tst sigcont4-p.tst sigcont5-p.tst sigcont6-p.tst sigcont7-p.tst sigcont8-p.tst sighup1-p.tst sighup2-p.tst sighup3-p.tst sighup4-p.tst sighup5-p.tst sighup6-p.tst sighup7-p.tst sighup8-p.tst sigint1-p.tst sigint2-p.tst sigint3-p.tst sigint4-p.tst sigint5-p.tst sigint6-p.tst sigint7-p.tst sigint8-p.tst sigquit1-p.tst sigquit2-p.tst sigquit3-p.tst sigquit4-p.tst sigquit5-p.tst sigquit6-p.tst sigquit7-p.tst sigquit8-p.tst sigstop3-p.tst sigstop7-p.tst sigterm1-p.tst sigterm2-p.tst sigterm3-p.tst sigterm4-p.tst sigterm5-p.tst sigterm6-p.tst sigterm7-p.tst sigterm8-p.tst sigtstp3-p.tst sigtstp4-p.tst sigtstp7-p.tst sigtstp8-p.tst sigttin3-p.tst sigttin4-p.tst sigttin7-p.tst sigttin8-p.tst sigttou3-p.tst sigttou4-p.tst sigttou7-p.tst sigttou8-p.tst sigurg1-p.tst sigurg2-p.tst sigurg3-p.tst sigurg4-p.tst sigurg5-p.tst sigurg6-p.tst sigurg7-p.tst sigurg8-p.tst
POSIX_TEST_SOURCES = $(POSIX_SIGNAL_TEST_SOURCES) alias-p.tst andor-p.tst arith-p.tst arithshift-p.tst async-p.tst bg-p.tst break-p.tst builtins-p.tst case-p.tst cd-p.tst cmdsub-p.tst command-p.tst comment-p.tst continue-p.tst declutil-p.tst diag-posish.tst dot-p.tst errexit-p.tst error-p.tst eval-p.tst exec-p.tst exit-p.tst export-p.tst fg-p.tst fnmatch-p.tst for-p.tst fsplit-p.tst function-p.tst getopts-p.tst grouping-p.tst if-p.tst input-p.tst job-p.tst jobpipe-p.tst jobspec-p.tst kill1-p.tst kill2-p.tst kill3-p.tst kill4-p.tst lineno-p.tst nop-p.tst option-p.tst param-p.tst path-p.tst pipeline-p.tst ppid-p.tst pwd-p.tst quote-p.tst read-p.tst readonly-p.tst redir-p.tst return-p.tst set-p.tst shift-p.tst simple-p.tst startup-p.tst test-p.tst testtty-p.tst tilde-p.tst trap-p.tst trapcmdsub-p.tst umask-p.tst unset-p.tst until-p.tst wait-p.tst while-p.tst

TEST_SOURCES = $(POSIX_TEST_SOURCES)
TEST_RESULTS = $(TEST_SOURCES:.tst=.trs)
SUMMARY = summary.log
SMOKE_TEST_SOURCES ?= \
	nop-p.tst \
	andor-p.tst \
	exec-p.tst \
	simple-p.tst \
	sigstop3-p.tst
SMOKE_RESULTS = $(SMOKE_TEST_SOURCES:.tst=.trs)
SMOKE_SUMMARY = summary-smoke.log
STOP_TEST_SOURCES = sigstop3-p.tst sigstop7-p.tst sigtstp3-p.tst sigtstp4-p.tst sigtstp7-p.tst sigtstp8-p.tst sigttin3-p.tst sigttin4-p.tst sigttin7-p.tst sigttin8-p.tst sigttou3-p.tst sigttou4-p.tst sigttou7-p.tst sigttou8-p.tst
SIGNAL_TEST_SOURCES = $(POSIX_SIGNAL_TEST_SOURCES)
SIGNAL_SUMMARY = summary-signal.log
REGRESSION_TEST_SOURCES = sigtstp4-p.tst sigttin4-p.tst sigttou4-p.tst command-p.tst jobspec-p.tst jobpipe-p.tst arithshift-p.tst pwd-p.tst trapcmdsub-p.tst prompt-posish.tst startup-posish.tst diag-posish.tst
FULLTRUTH_SUMMARY ?= summary-fulltruth.log
FULLTRUTH_CLASSIFICATION_CSV ?= summary-fulltruth.csv
TESTCASE_TIMEOUT ?= 0
# Stop-family signal tests are most reliable in truth mode (no per-case watchdog).
TESTCASE_TIMEOUT_STOP ?= 0
TESTCASE_TIMEOUT_SIGNAL ?= 0
SIGNAL_FILE_TIMEOUT ?= 180
SIGNAL_FILE_TIMEOUT_KILL ?= 5
FILE_TIMEOUT ?= 200
KILL_AFTER ?= 5

TESTEE ?= /bin/sh
RUN_TEST = ./resetsig $(YASH_RUNNER) ./run-test.sh

BYPRODUCTS = $(SOURCES:.c=.o) $(TESTERS) $(TEST_RESULTS) $(SUMMARY) $(SMOKE_SUMMARY) $(SIGNAL_SUMMARY) $(FULLTRUTH_SUMMARY) $(FULLTRUTH_CLASSIFICATION_CSV) summary-fulltruth.*.list *.dSYM tmp.* tmp.queue

check-yash-runner:
	@if [ -z "$(YASH_RUNNER)" ] || ! [ -x "$(YASH_RUNNER)" ]; then \
		echo "ERROR: yash runner not found." >&2; \
		echo "Install the latest yash (recommended: build it from source)," >&2; \
		echo "or set YASH_RUNNER=/absolute/path/to/yash." >&2; \
		exit 1; \
	fi

test: check-yash-runner tester $(TEST_RESULTS)
	@$(SHELL) ./summarize.sh $(TEST_RESULTS) >| $(SUMMARY)
	@tail -n 6 $(SUMMARY)
	@tail -n 6 $(SUMMARY) | grep '^ERROR:' | \
		(read _ fail_count && \
		if [ "$$fail_count" -ne 0 ]; then \
			echo See tests/posix/$(SUMMARY) for details; \
			exit 1; \
		fi)

test-posix: test

test-smoke: check-yash-runner tester $(SMOKE_RESULTS)
	@$(SHELL) ./summarize.sh $(SMOKE_RESULTS) >| $(SMOKE_SUMMARY)
	@tail -n 6 $(SMOKE_SUMMARY)
	@tail -n 6 $(SMOKE_SUMMARY) | grep '^ERROR:' | \
		(read _ fail_count && \
		if [ "$$fail_count" -ne 0 ]; then \
			echo See tests/posix/$(SMOKE_SUMMARY) for details; \
			exit 1; \
		fi)

test-one: check-yash-runner tester
	@test -n "$(TEST)" || (echo "TEST=<name-p.tst> is required" >&2; exit 2)
	@$(MAKE) $(TEST:.tst=.trs) TESTEE="$(TESTEE)"

test-stop: check-yash-runner tester
	@$(MAKE) test \
		TEST_SOURCES="$(STOP_TEST_SOURCES)" \
		TESTCASE_TIMEOUT="$(TESTCASE_TIMEOUT_STOP)" \
		TESTEE="$(TESTEE)" \
		YASH_RUNNER="$(YASH_RUNNER)"

test-signal: check-yash-runner tester
	@$(MAKE) -B test \
		TEST_SOURCES="$(SIGNAL_TEST_SOURCES)" \
		TESTCASE_TIMEOUT="$(TESTCASE_TIMEOUT_SIGNAL)" \
		TESTEE="$(TESTEE)" \
		YASH_RUNNER="$(YASH_RUNNER)"

test-signal-contained: check-yash-runner tester
	@$(SHELL) ../../scripts/run-posix-signal-contained.sh \
		--tests-dir . \
		--testee "$(TESTEE)" \
		--yash-runner "$(YASH_RUNNER)" \
		--test-sources "$(SIGNAL_TEST_SOURCES)" \
		--testcase-timeout "$(TESTCASE_TIMEOUT_SIGNAL)" \
		--file-timeout "$(SIGNAL_FILE_TIMEOUT)" \
		--kill-after "$(SIGNAL_FILE_TIMEOUT_KILL)" \
		--summary "$(SIGNAL_SUMMARY)"

test-posix-contained: check-yash-runner tester
	@$(SHELL) ../../scripts/run-posix-fulltruth-contained.sh \
		--tests-dir . \
		--testee "$(TESTEE)" \
		--yash-runner "$(YASH_RUNNER)" \
		--test-sources "$(POSIX_TEST_SOURCES)" \
		--testcase-timeout "$(TESTCASE_TIMEOUT)" \
		--file-timeout "$(FILE_TIMEOUT)" \
		--kill-after "$(KILL_AFTER)" \
		--summary "$(FULLTRUTH_SUMMARY)" \
		--classification-csv "$(FULLTRUTH_CLASSIFICATION_CSV)"

test-regressions: check-yash-runner tester
	@$(MAKE) -B test \
		TEST_SOURCES="$(REGRESSION_TEST_SOURCES)" \
		TESTCASE_TIMEOUT="$(TESTCASE_TIMEOUT_SIGNAL)" \
		TESTEE="$(TESTEE)" \
		YASH_RUNNER="$(YASH_RUNNER)"

$(SUMMARY): $(TEST_RESULTS)
	$(SHELL) ./summarize.sh $(TEST_RESULTS) >| $@

$(TEST_RESULTS): $(TESTERS)

.tst.trs:
	@set $(RUN_TEST) $(TESTEE) $<; \
	if grep -q %REQUIRETTY% $<; then \
		if ./ptwrap ./checkfg 2>/dev/null; then \
			set ./ptwrap "$$@"; \
		else \
			set $(SHELL) ./enqueue.sh "$$@"; \
		fi; \
	fi; \
	echo "$$*"; \
	TESTCASE_TIMEOUT="$(TESTCASE_TIMEOUT)" "$$@"

tester: $(TESTERS)

$(TESTERS):
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) -o $@ $@.c $(LDLIBS)

clean:
	rm -fr $(BYPRODUCTS)

.IGNORE: ptwrap
.PHONY: check-yash-runner test test-posix test-smoke test-one test-stop test-signal test-signal-contained test-posix-contained test-regressions tester clean
