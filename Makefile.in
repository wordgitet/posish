.POSIX:
.SUFFIXES: .c .o

SHELL = /bin/sh

CC = @CC@
CPPFLAGS = @CPPFLAGS@ -D_POSIX_C_SOURCE=200809L -Iinclude -Isrc -include config.h
CFLAGS = @CFLAGS@ -Wall -Wextra -Wpedantic
LDFLAGS = @LDFLAGS@
LIBS = @LIBS@
YASH_RUNNER = @YASH_RUNNER@

BUILD_DIR = build
TARGET = $(BUILD_DIR)/posish
METRICS_CSV = tmp/metrics/posix.csv

SRC = \
	src/main.c \
	src/shell.c \
	src/input.c \
	src/lexer.c \
	src/parser.c \
	src/arith.c \
	src/case_command.c \
	src/compound_parse.c \
	src/heredoc_command.c \
	src/expand.c \
	src/exec.c \
	src/redir.c \
	src/jobs.c \
	src/signals.c \
	src/trace.c \
	src/vars.c \
	src/options.c \
	src/path.c \
	src/error.c \
	src/arena.c \
	src/builtins/special.c \
	src/builtins/regular.c

OBJ = \
	src/main.o \
	src/shell.o \
	src/input.o \
	src/lexer.o \
	src/parser.o \
	src/arith.o \
	src/case_command.o \
	src/compound_parse.o \
	src/heredoc_command.o \
	src/expand.o \
	src/exec.o \
	src/redir.o \
	src/jobs.o \
	src/signals.o \
	src/trace.o \
	src/vars.o \
	src/options.o \
	src/path.o \
	src/error.o \
	src/arena.o \
	src/builtins/special.o \
	src/builtins/regular.o

SMOKE_TEST_SOURCES = \
	nop-p.tst \
	andor-p.tst \
	exec-p.tst \
	simple-p.tst \
	sigstop3-p.tst
TESTCASE_TIMEOUT ?= 0
# Stop-family signal tests are most reliable in truth mode (no per-case watchdog).
TESTCASE_TIMEOUT_STOP ?= 0
TESTCASE_TIMEOUT_SIGNAL ?= 0
SIGNAL_FILE_TIMEOUT ?= 180
SIGNAL_FILE_TIMEOUT_KILL ?= 5
FILE_TIMEOUT ?= 200
KILL_AFTER ?= 5
FULLTRUTH_SUMMARY ?= summary-fulltruth.log
FULLTRUTH_CSV ?= summary-fulltruth.csv

all: $(TARGET)

$(TARGET): $(OBJ)
	mkdir -p $(BUILD_DIR)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $(OBJ) $(LIBS)

.c.o:
	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@

test-posix: $(TARGET)
	@if [ -n "$(TESTEE)" ]; then testee="$(TESTEE)"; else testee="`pwd`/$(TARGET)"; fi; \
	$(MAKE) -C tests/posix test-posix \
		YASH_RUNNER="$(YASH_RUNNER)" \
		TESTEE="$$testee" \
		TESTCASE_TIMEOUT="$(TESTCASE_TIMEOUT)"

test-smoke: $(TARGET)
	@if [ -n "$(TESTEE)" ]; then testee="$(TESTEE)"; else testee="`pwd`/$(TARGET)"; fi; \
	$(MAKE) -C tests/posix test-smoke \
		YASH_RUNNER="$(YASH_RUNNER)" \
		TESTEE="$$testee" \
		SMOKE_TEST_SOURCES="$(SMOKE_TEST_SOURCES)" \
		TESTCASE_TIMEOUT="$(TESTCASE_TIMEOUT)"

test-stop: $(TARGET)
	@if [ -n "$(TESTEE)" ]; then testee="$(TESTEE)"; else testee="`pwd`/$(TARGET)"; fi; \
	$(MAKE) -C tests/posix test-stop \
		YASH_RUNNER="$(YASH_RUNNER)" \
		TESTEE="$$testee" \
		TESTCASE_TIMEOUT_STOP="$(TESTCASE_TIMEOUT_STOP)"

test-signal: $(TARGET)
	@if [ -n "$(TESTEE)" ]; then testee="$(TESTEE)"; else testee="`pwd`/$(TARGET)"; fi; \
	$(MAKE) -C tests/posix test-signal \
		YASH_RUNNER="$(YASH_RUNNER)" \
		TESTEE="$$testee" \
		TESTCASE_TIMEOUT_SIGNAL="$(TESTCASE_TIMEOUT_SIGNAL)"

test-signal-contained: $(TARGET)
	@if [ -n "$(TESTEE)" ]; then testee="$(TESTEE)"; else testee="`pwd`/$(TARGET)"; fi; \
	$(MAKE) -C tests/posix test-signal-contained \
		YASH_RUNNER="$(YASH_RUNNER)" \
		TESTEE="$$testee" \
		TESTCASE_TIMEOUT_SIGNAL="$(TESTCASE_TIMEOUT_SIGNAL)" \
		SIGNAL_FILE_TIMEOUT="$(SIGNAL_FILE_TIMEOUT)" \
		SIGNAL_FILE_TIMEOUT_KILL="$(SIGNAL_FILE_TIMEOUT_KILL)"

test-regressions: $(TARGET)
	@if [ -n "$(TESTEE)" ]; then testee="$(TESTEE)"; else testee="`pwd`/$(TARGET)"; fi; \
	$(MAKE) -C tests/posix test-regressions \
		YASH_RUNNER="$(YASH_RUNNER)" \
		TESTEE="$$testee" \
		TESTCASE_TIMEOUT_SIGNAL="$(TESTCASE_TIMEOUT_SIGNAL)"

test-posix-rebaseline: $(TARGET)
	@if [ -n "$(TESTEE)" ]; then testee="$(TESTEE)"; else testee="`pwd`/$(TARGET)"; fi; \
	$(MAKE) -C tests/posix test-posix-contained \
		YASH_RUNNER="$(YASH_RUNNER)" \
		TESTEE="$$testee" \
		TESTCASE_TIMEOUT="0" \
		FILE_TIMEOUT="$(FILE_TIMEOUT)" \
		KILL_AFTER="$(KILL_AFTER)" \
		FULLTRUTH_SUMMARY="$(FULLTRUTH_SUMMARY)" \
		FULLTRUTH_CLASSIFICATION_CSV="$(FULLTRUTH_CSV)"

sync-posix-checklist:
	$(SHELL) scripts/sync-posix-checklist.sh \
		--csv tests/posix/$(FULLTRUTH_CSV) \
		--checklist tests/POSIX_CHECKLIST.md

rebaseline-fulltruth: test-posix-rebaseline sync-posix-checklist
	@awk -F, '\
	BEGIN { \
		full_pass=0; partial_fail=0; full_fail=0; timeout=0; missing=0; ok=0; err=0; skip=0; \
	} \
	NR == 1 { next } \
	{ \
		if ($$6 == "FULL_PASS") full_pass++; \
		else if ($$6 == "PARTIAL_FAIL") partial_fail++; \
		else if ($$6 == "FULL_FAIL") full_fail++; \
		else if ($$6 == "TIMEOUT") timeout++; \
		else if ($$6 == "MISSING") missing++; \
		ok += $$3 + 0; \
		err += $$4 + 0; \
		skip += $$5 + 0; \
	} \
	END { \
		ratio = (ok + err == 0) ? 0 : ok / (ok + err); \
		printf("FULL_PASS: %d\n", full_pass); \
		printf("PARTIAL_FAIL: %d\n", partial_fail); \
		printf("FULL_FAIL: %d\n", full_fail); \
		printf("TIMEOUT: %d\n", timeout); \
		printf("MISSING: %d\n", missing); \
		printf("OK: %d\n", ok); \
		printf("ERROR: %d\n", err); \
		printf("SKIPPED: %d\n", skip); \
		printf("RATIO_OK_OVER_OK_PLUS_ERROR: %.4f\n", ratio); \
	}' tests/posix/$(FULLTRUTH_CSV)

metrics: $(TARGET)
	mkdir -p tmp/metrics
	@if [ -n "$(METRICS_TEST_SOURCES)" ]; then \
		$(MAKE) -C tests/posix test \
			YASH_RUNNER="$(YASH_RUNNER)" \
			TESTEE="`pwd`/$(TARGET)" \
			TEST_SOURCES="$(METRICS_TEST_SOURCES)" || true; \
	else \
		$(MAKE) test-posix || true; \
	fi
	$(SHELL) scripts/append-metrics.sh tests/posix/summary.log $(METRICS_CSV)

clean:
	rm -f $(OBJ)
	rm -rf $(BUILD_DIR)
	$(MAKE) -C tests/posix clean

.PHONY: all clean test-posix test-smoke test-stop test-signal test-signal-contained test-regressions test-posix-rebaseline sync-posix-checklist rebaseline-fulltruth metrics
